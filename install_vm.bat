@echo off
REM ═══════════════════════════════════════════════════════════════
REM  Скрипт установки Yukitery на виртуальную машину
REM ═══════════════════════════════════════════════════════════════

echo ==========================================
echo   Установка Yukitery на VM
echo ==========================================
echo.

REM Запрос URL репозитория
echo Введите URL GitHub репозитория (например: https://github.com/ваш_аккаунт/yukitery):
set /p REPO_URL=

echo.
echo Клонирование репозитория...
git clone %REPO_URL% C:\yukitery

echo.
echo Переход в директорию проекта...
cd C:\yukitery

echo.
echo Установка Python зависимостей...
pip install -r requirements.txt

echo.
echo ==========================================
echo   Установка завершена!
echo ==========================================
echo.
echo Запуск сайта...
python app.py
